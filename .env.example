# Copy this to .env for local development

# PostgreSQL connection string
# Railway provides this automatically as DATABASE_URL
DATABASE_URL=postgresql://user:password@localhost:5432/pickmates

# Express session secret — use a long random string in production
SESSION_SECRET=change-me-to-something-random

# API key to trigger a manual scrape via POST /api/scrape
SCRAPE_API_KEY=change-me-too

# Set to 'production' on Railway
NODE_ENV=development

# Only needed in production (Docker) — points to system Chromium
# Railway sets this automatically if you use the Dockerfile provided
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
