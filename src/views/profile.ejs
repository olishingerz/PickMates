<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Profile – PickMates</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <header>
    <div class="header-inner">
      <a href="/" class="logo"><span class="logo-flag">⛳</span> PickMates</a>
      <nav><%- include('partials/nav') %></nav>
    </div>
  </header>

  <main>
    <div class="page-header">
      <h1>Profile</h1>
    </div>

    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
    <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>

    <!-- ── Stats ──────────────────────────────────────────────────────────── -->
    <div class="card" style="margin-bottom:1.2rem">
      <h2 class="section-title">Your stats</h2>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.2rem">
        <div>
          <p class="label-small" style="margin-bottom:.6rem">⛳ Golf Draft</p>
          <div style="display:flex;flex-direction:column;gap:.4rem">
            <div class="stat-row"><span class="muted">Games played</span><strong><%= golfStats.golf_played || 0 %></strong></div>
            <div class="stat-row"><span class="muted">Team pot wins</span><strong><%= golfStats.team_wins || 0 %></strong></div>
            <div class="stat-row"><span class="muted">Individual pot wins</span><strong><%= golfStats.indiv_wins || 0 %></strong></div>
          </div>
        </div>
        <div>
          <p class="label-small" style="margin-bottom:.6rem">🏆 Last Man Standing</p>
          <div style="display:flex;flex-direction:column;gap:.4rem">
            <div class="stat-row"><span class="muted">Games played</span><strong><%= lmsStats.lms_played || 0 %></strong></div>
            <div class="stat-row"><span class="muted">Wins</span><strong><%= lmsStats.lms_wins || 0 %></strong></div>
            <div class="stat-row"><span class="muted">Furthest week</span><strong><%= lmsStats.furthest_week || '—' %></strong></div>
          </div>
        </div>
      </div>

      <% if (pickHistory.length > 0) { %>
        <%
          // Group pick history by game
          const gameMap = new Map();
          pickHistory.forEach(p => {
            if (!gameMap.has(p.game_id)) gameMap.set(p.game_id, { game_name: p.game_name, tournament_name: p.tournament_name, tournament_complete: p.tournament_complete, picks: [] });
            gameMap.get(p.game_id).picks.push(p);
          });
          const games = [...gameMap.values()];
        %>
        <div style="margin-top:1.2rem;border-top:1px solid var(--border);padding-top:1rem">
          <p class="label-small" style="margin-bottom:.6rem">Pick history</p>
          <% games.forEach(g => { %>
            <div style="margin-bottom:.8rem">
              <p style="font-size:.85rem;font-weight:600;margin-bottom:.3rem">
                <%= g.game_name %><% if (g.tournament_name) { %> <span class="muted">· <%= g.tournament_name %></span><% } %>
              </p>
              <div style="display:flex;flex-wrap:wrap;gap:.3rem">
                <% g.picks.forEach(p => { %>
                  <%
                    const sc = p.score_to_par;
                    const cls = sc === null ? '' : sc < 0 ? 'under' : sc === 0 ? 'even' : 'over';
                    const label = sc === null ? '' : (sc === 0 ? 'E' : sc > 0 ? '+' + sc : '' + sc);
                  %>
                  <span style="display:inline-flex;align-items:center;gap:.3rem;padding:.2rem .55rem;background:var(--bg);border:1px solid var(--border);border-radius:20px;font-size:.8rem">
                    <%= p.player_name %>
                    <% if (p.made_cut === false) { %><span class="cut-badge" style="font-size:.68rem">CUT</span>
                    <% } else if (sc !== null) { %><span class="score-badge <%= cls %>" style="font-size:.72rem;padding:.05rem .3rem"><%= label %></span>
                    <% } %>
                  </span>
                <% }) %>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="profile-grid">

      <!-- ── Avatar ──────────────────────────────────────────────────────── -->
      <div class="card profile-avatar-card">
        <h2 class="section-title">Profile picture</h2>
        <div class="avatar-preview">
          <% if (profileUser.avatar) { %>
            <img src="<%= profileUser.avatar %>" alt="Profile picture" class="avatar-img" />
          <% } else { %>
            <div class="avatar-placeholder"><%= profileUser.username.charAt(0).toUpperCase() %></div>
          <% } %>
        </div>
        <form action="/profile/avatar" method="POST" enctype="multipart/form-data" style="margin-top:.8rem">
          <div class="form-group">
            <label for="avatar">Upload image <span class="muted">(max 2 MB)</span></label>
            <input type="file" id="avatar" name="avatar" accept="image/*" />
          </div>
          <div style="display:flex;gap:.5rem;flex-wrap:wrap">
            <button type="submit" class="btn btn-sm">Save picture</button>
            <% if (profileUser.avatar) { %>
              <button type="submit" name="remove_avatar" value="1" class="btn btn-sm btn-ghost" style="color:var(--text)">Remove</button>
            <% } %>
          </div>
        </form>
      </div>

      <!-- ── Username ────────────────────────────────────────────────────── -->
      <div class="card">
        <h2 class="section-title">Username</h2>
        <form action="/profile/username" method="POST">
          <div class="form-group">
            <label for="username">Username</label>
            <input type="text" id="username" name="username"
                   value="<%= profileUser.username %>" required
                   minlength="2" maxlength="50" autocomplete="username" />
          </div>
          <button type="submit" class="btn btn-sm">Save username</button>
        </form>
      </div>

      <!-- ── Email / notifications ─────────────────────────────────────── -->
      <div class="card">
        <h2 class="section-title">Email &amp; notifications</h2>
        <form action="/profile/email" method="POST">
          <div class="form-group">
            <label for="email">Email address</label>
            <input type="email" id="email" name="email"
                   value="<%= profileUser.email || '' %>" autocomplete="email"
                   placeholder="you@example.com" />
            <small>Used to notify you when it's your turn in a draft or before an LMS deadline. Never shared.</small>
          </div>
          <button type="submit" class="btn btn-sm">Save email</button>
        </form>
      </div>

      <!-- ── Password ────────────────────────────────────────────────────── -->
      <div class="card">
        <h2 class="section-title">Change password</h2>
        <form action="/profile/password" method="POST">
          <div class="form-group">
            <label for="current_password">Current password</label>
            <input type="password" id="current_password" name="current_password"
                   required autocomplete="current-password" />
          </div>
          <div class="form-group">
            <label for="password">New password</label>
            <input type="password" id="password" name="password"
                   required minlength="6" autocomplete="new-password" />
            <small>At least 6 characters</small>
          </div>
          <div class="form-group">
            <label for="confirmPassword">Confirm new password</label>
            <input type="password" id="confirmPassword" name="confirmPassword"
                   required autocomplete="new-password" />
          </div>
          <button type="submit" class="btn btn-sm">Save password</button>
        </form>
      </div>

    </div>
  </main>

  <footer>
    <p>PickMates · Golf draft competitions</p>
  </footer>
</body>
</html>
