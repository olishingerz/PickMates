<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PickMates</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <header>
    <div class="header-inner">
      <a href="/" class="logo"><span class="logo-flag">⛳</span> PickMates</a>
      <nav><%- include('partials/nav') %></nav>
    </div>
  </header>

  <main>
    <div class="page-header">
      <h1>Games</h1>
      <p class="last-updated">Pick your tournament, draft your squad, track the action.</p>
    </div>

    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
    <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>

    <!-- ── Game list ──────────────────────────────────────────────────────── -->
    <% if (games.length === 0) { %>
      <div class="card empty-state">
        <p>No games yet.<% if (user && user.isAdmin) { %> Create the first one below.<% } %></p>
      </div>
    <% } else { %>
      <div class="games-grid">
        <% games.forEach(g => { %>
          <%
            let statusLabel = 'Pre-Draft';
            let statusClass = 'status-upcoming';
            if (g.tournament_complete)      { statusLabel = 'Complete';    statusClass = 'status-done'; }
            else if (g.is_complete)         { statusLabel = 'In Progress'; statusClass = 'status-live'; }
            else if (g.is_started)          { statusLabel = 'Draft';       statusClass = 'status-draft'; }
          %>
          <div class="card game-card">
            <div class="game-card-header">
              <div>
                <div style="display:flex;align-items:center;gap:.5rem;flex-wrap:wrap">
                  <h2 class="game-card-name"><%= g.name %></h2>
                  <span class="game-type-badge <%= g.game_type === 'last_man_standing' ? 'game-type-lms' : 'game-type-golf' %>">
                    <%= g.game_type === 'last_man_standing' ? '🏆 Last Man Standing' : '⛳ Golf Draft' %>
                  </span>
                </div>
                <% if (g.tournament_name) { %>
                  <p class="muted game-card-tournament"><%= g.tournament_name %></p>
                <% } else { %>
                  <p class="muted game-card-tournament">No tournament selected</p>
                <% } %>
              </div>
              <span class="status-badge <%= statusClass %>"><%= statusLabel %></span>
            </div>
            <div class="game-card-meta">
              <span class="muted"><%= g.participant_count %> player<%= g.participant_count !== 1 ? 's' : '' %></span>
            </div>
            <div class="game-card-actions">
              <a href="/game/<%= g.id %>" class="btn btn-sm">Leaderboard</a>
              <% if (user) { %>
                <% const isGameHost = user.isAdmin || g.host_user_id === user.id; %>
                <% if (!g.is_started) { %>
                  <% if (g.user_joined || isGameHost) { %>
                    <a href="/game/<%= g.id %>/draft" class="btn btn-sm" style="background:#f59e0b;color:#1a1a1a"><%= g.game_type === 'last_man_standing' ? 'Lobby' : 'Draft room' %></a>
                  <% } %>
                  <% if (!g.user_joined) { %>
                    <form action="/game/<%= g.id %>/join" method="POST" style="display:inline">
                      <button type="submit" class="btn btn-sm" style="background:var(--green);color:#fff">Join game</button>
                    </form>
                  <% } %>
                <% } else if (g.is_started && !g.is_complete) { %>
                  <% if (g.user_joined || isGameHost) { %>
                    <% if (g.game_type === 'last_man_standing') { %>
                      <a href="/game/<%= g.id %>/lms/picks" class="btn btn-sm" style="background:#f59e0b;color:#1a1a1a">Make pick</a>
                    <% } else { %>
                      <a href="/game/<%= g.id %>/draft" class="btn btn-sm" style="background:#f59e0b;color:#1a1a1a">Draft room</a>
                    <% } %>
                  <% } %>
                <% } %>
                <% if (g.user_joined) { %>
                  <span class="muted" style="font-size:.82rem;align-self:center">✓ Joined</span>
                <% } %>
              <% } else { %>
                <% if (!g.is_started) { %>
                  <a href="/auth/register" class="btn btn-sm" style="background:var(--green);color:#fff">Join game</a>
                <% } %>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

    <% if (user && (user.isAdmin || user.isPaid)) { %>
      <div style="margin-top:1.5rem;text-align:center">
        <a href="/games/create" class="btn" style="font-size:.95rem;padding:.55rem 1.4rem">＋ Create New Game</a>
      </div>
    <% } %>

    <!-- ── Winners Club ──────────────────────────────────────────────── -->
    <% if (winners.length > 0) { %>
      <div style="margin-top:2.5rem">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem">
          <h2 class="section-title" style="font-size:1.2rem;margin-bottom:0">🏆 Winners Club</h2>
          <a href="/hall-of-fame" style="font-size:.82rem">See all →</a>
        </div>
        <div class="winners-grid">
          <% winners.forEach(w => { %>
            <a href="/game/<%= w.id %>" class="winner-card">
              <div class="winner-card-tournament">
                <span class="game-type-badge <%= w.game_type === 'last_man_standing' ? 'game-type-lms' : 'game-type-golf' %>" style="margin-bottom:.4rem;display:inline-block">
                  <%= w.game_type === 'last_man_standing' ? '🏆 Last Man Standing' : '⛳ Golf Draft' %>
                </span>
                <div class="winner-card-name"><%= w.name %></div>
                <% if (w.tournament_name) { %><div class="muted" style="font-size:.8rem"><%= w.tournament_name %></div><% } %>
              </div>
              <div class="winner-card-prizes">
                <% if (w.winner_username) { %>
                  <div class="winner-entry">
                    <span class="winner-trophy">🥇</span>
                    <span class="winner-name"><%= w.winner_username %></span>
                    <span class="winner-label"><%= w.game_type === 'last_man_standing' ? '· Last Man Standing' : '· Team pot' %></span>
                  </div>
                <% } %>
                <% if (w.winner_individual_username && w.game_type === 'golf_draft') { %>
                  <div class="winner-entry">
                    <span class="winner-trophy">🎯</span>
                    <span class="winner-name"><%= w.winner_individual_username %></span>
                    <span class="winner-label">· Individual pot</span>
                  </div>
                <% } %>
              </div>
            </a>
          <% }) %>
        </div>
      </div>
    <% } %>

  </main>

  <footer>
    <p>PickMates · Golf draft competitions</p>
  </footer>
</body>
</html>
